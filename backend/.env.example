# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=sqlite:./database.db
# For PostgreSQL: postgresql://user:password@localhost:5432/email_campaign

# Redis (for job queue)
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# SMTP Configuration (Default)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-not-regular-password
SMTP_FROM_NAME=Bulk Email Campaign
SMTP_FROM_EMAIL=noreply@emailcampaign.com
SMTP_ENCRYPTION=tls

# Email Queue Settings
QUEUE_CONCURRENCY=5
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY=5000
QUEUE_RATE_LIMIT=10

# Email Provider APIs (Optional)
SENDGRID_API_KEY=your-sendgrid-api-key
AWS_SES_ACCESS_KEY_ID=your-aws-access-key
AWS_SES_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_SES_REGION=us-east-1
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.yourdomain.com

# CORS
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=debug

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173
